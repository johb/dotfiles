# ============================================================================
# This file contains shell agnostic (tested on sh, bash and zsh)
# functions and settings like aliases, env vars etc.
# ============================================================================
OS="$(uname)"

if type vim >/dev/null 2>&1; then
	export EDITOR="vim"
	export VISUAL="vim"
fi

# ----------------------------------------------------------------------------
# PATH
# ----------------------------------------------------------------------------
# ... macOS
if [ "$OS" = "Darwin" ]; then
	# Homebrew
	[ -d /opt/homebrew/bin ] && PATH="$PATH":/opt/homebrew/bin
	# local Homebrew
	[ -d "$HOME"/homebrew/bin ] && PATH="$PATH":"$HOME"/homebrew/bin
	# MacPorts
	[ -d /opt/local/bin ] && PATH="$PATH":/opt/local/bin
	# local MacPorts installation
	[ -d "$HOME"/ports ] && PATH="$PATH":"$HOME"/ports/bin
	# Local docker installation
	[ -d "$HOME"/.docker/bin ] && PATH="$PATH":"$HOME"/.docker/bin
	# Local, self compiled applications
	[ -d "$HOME"/usr/bin ] && PATH="$PATH":"$HOME"/usr/bin
# ... Linux
#elif [ "$OS" = "Linux" ]; then
fi

# ----------------------------------------------------------------------------
# Aliases
# ----------------------------------------------------------------------------
# ... macOS
if [ "$OS" = "Darwin" ]; then
	# Quicklook
	preview='qlmanage -p'

	[ -f "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" ] &&
		alias code='/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code'

	[ -f "${HOME}/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" ] &&
		alias code='${HOME}/Applications/Visual\ Studio\ Code.app/Contents/Resources/app/bin/code'
	alias desktop-logout='launchctl bootout user/$(id -u)'

	# Use pandoc docker container if docker is installed
	if command -v docker >/dev/null; then
		alias pandoc='docker run --rm -v "$(pwd):/data" --user "$(id -u):$(id -g)" pandoc/latex:latest-ubuntu'
		alias pdflatex='docker run --rm -it -v "$(pwd):/data" --user "$(id -u):$(id -g)" pandoctex:latest xelatex'
		alias xelatex='docker run --rm -it -v "$(pwd):/data" --user "$(id -u):$(id -g)" pandoctex:latest pdflatex'
		alias pandoc='docker run --rm -it -v "$(pwd):/data" --user "$(id -u):$(id -g)" pandoctex:latest pandoc'
	fi
# ... Linux
#elif [ "$OS" = "Linux" ]; then
fi

alias ..='cd ..'
alias ...='cd ../..'
alias ls='ls --color=auto'
alias ll='ls -alFh'
alias lll='ls -alFhe'
alias la='ls -A'
# Do not clear screen after exitting less
alias less='less -X'
# ls long without group sorted by date
alias lsd='ls -hoAt --time-style=long-iso'
# ls long sorted alphabetically
alias lsl='ls -hAl --time-style=long-iso'
alias l='ls -CF'
# ls long without group sorted by date
alias lsd='ls -hoAt --time-style=long-iso'
# ls long sorted alphabetically
alias lsl='ls -hAl --time-style=long-iso'

alias grep='grep --color=auto'
alias dotfiles='git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
alias ddusb='dd bs=16M status=progress oflag=sync'

# --- git
alias git-info='git status && echo && git branch -vv && echo && git remote -v && echo && git log --oneline -n 5'
alias git-graph='git log --oneline --graph --decorate --all'
# ----------------------------------------------------------------------------
# Colors
# ----------------------------------------------------------------------------
# Terminal colors:
# background:	#191D27
# color:		normal|bright
# black:		#38424B|#4B5864
# red:			#BF546A|#D95F78
# green:		#6CAA70|#7CC481
# yellow:		#D8BA17|#F4D31A
# blue:			#3C81AC|#4594C5
# magenta:		#4594C5|#CE80C6
# cyan:			#00A6B9|#00BDD3
# white:		#ECEFF4|#F6F9FF

export C_RESET='\[\e[0m\]'
export C_OK='\[\e[32m\]'
export C_ERROR='\[\e[31m\]'
export C_WARN='\[\e[33m\]'
export C_INFO='\[\e[34m\]'
export C_HILITE='\[\e[36m\]'
export C_DIM='\[\e[90m\]'

# rohe ANSI-Sequenzen
export COLOR_RESET='\e[0m'
export COLOR_OK='\e[32m'
export COLOR_ERROR='\e[31m'
export COLOR_WARN='\e[33m'
export COLOR_INFO='\e[34m'
export COLOR_HILITE='\e[36m'
export COLOR_DIM='\e[90m'
# ----------------------------------------------------------------------------
# Functions
# ----------------------------------------------------------------------------

# Open man page in Preview app.
function man_preview() {

	# Only macOS
	[ "$OS" != "Darwin" ] && echo "Works only on macOS" && return 1

	mandoc -T pdf "$(/usr/bin/man -w $@)" | open -fa Preview
}

# Open man page in separate yellow terminal window.
function xman() {
	# Only macOS
	[ "$OS" != "Darwin" ] && echo "Works only on macOS" && return 1

	# If more than one arg, then assume the first arg is the section.
	if [ ! -z "$2" ]; then
		section="$1"
		shift
		open x-man-page://$section/$@
	else
		open x-man-page://$@
	fi
}

function set_hostname() {
	[ -z "$1" ] && echo "Usage: set_hostname HOSTNAME" && return 1

	if [ "$OS" = "Darwin" ]; then
		# ComputerName: user-friendly name for the system.
		# LocalHostName: local (Bonjour) host name.
		# HostName: The name associated with hostname and gethostname
		sudo scutil --set ComputerName "$1"
		sudo scutil --set LocalHostName "$1"
		sudo scutil --set HostName "$1"
	elif [ "$OS" = "Linux" ]; then
		sudo hostnamectl hostname "$1"
	fi
}

# List all files in passed search path sorted by modification time.
find_files_modified() {
	SEARCH_PATH="."
	[ -n "$1" ] && SEARCH_PATH="$1"
	if [ "$OS" = "Darwin" ]; then
		find "$SEARCH_PATH" -type f -exec stat -f "%Sm %N" -t '%Y-%m-%d' {} + |
			sort |
			grep --color=auto -E '[^/]+$'
	elif [ "$OS" = "Linux" ]; then
		find "$SEARCH_PATH" -type f -printf '%TY-%Tm-%Td %p\n' |
			sort |
			grep --color=auto -E '[^/]+$'
	else
		return 1
	fi
}

# Colors
show_colors() {
	for i in {0..255}; do
		printf "\e[48;5;${i}m%4d\e[0m" "$i"
		(((i + 1) % 16 == 0)) && echo
	done

	echo
	echo "${COLOR_OK}\$COLOR_OK${COLOR_RESET}"
	echo "${COLOR_ERROR}\$COLOR_ERROR${COLOR_RESET}"
	echo "${COLOR_WARN}\$COLOR_WARN${COLOR_RESET}"
	echo "${COLOR_INFO}\$COLOR_INFO${COLOR_RESET}"
	echo "${COLOR_HILITE}\$COLOR_HILITE${COLOR_RESET}"
	echo "${COLOR_DIM}\$COLOR_DIM${COLOR_RESET}"
}

# Generate random passwords
gen_password() {
	local length=12
	[ -n "$1" ] && length="$1"
	pass=$(LC_ALL=C tr -dc 'A-Za-z0-9!?$%&/=():' </dev/random | head -c "$length")
	echo "$pass"
}

# Recursivly set file mode to sane and private (750 directories, 640 files).
repair_filemod() {
	CWD="$(pwd)"
	echo "cwd: ${CWD}, setting all directories to 750 and all files to 640? (y/N)"
	read RESPONSE
	if [ "$RESPONSE" = "y" ]; then
		find "$CWD" -type d -exec chmod 750 {} \;
		find "$CWD" -type f -exec chmod 640 {} \;
	else
		echo "NO"
	fi
}

# List all aliases defined in "$HOME"/.ssh/config
lsssh() {
	awk '/^Host /{h=$2} /^[[:space:]]*Hostname /{printf "%s (@%s)\n", h, $2}' \
		"$HOME/.ssh/config"
}

# Show info about battery health condition
battery_health() {
	if [ "$OS" = "Darwin" ]; then
		filter='.SPPowerDataType[] |
    			select(._name == "spbattery_information") |
    			.sppower_battery_health_info |
    			{sppower_battery_health_maximum_capacity, sppower_battery_cycle_count}'

		system_profiler SPPowerDataType -json | jq "$filter"
	elif [ "$OS" = "Linux" ]; then
		if command -v inxi; then
			inxi --battery
		else
			echo "Error, install inxi tool."
			return 1
		fi
	else
		echo 'Error! Unknown OS ' "$OS"
		return 1
	fi
}

# Print out info about the passed certificate (PEM or DER encoded)
openssl__certinfo() {
	# $1: certfile
	[ -z "$1" ] && echo "Usage: openssl__certinfo CERTFILE" && return 1

	# Test certificate encoding
	if grep -q -- "-----BEGIN CERTIFICATE" "$1"; then
		echo "PEM encoded"
		# default is pem encoding
		# -noout: no output beside specified
		# -text: full details of cert in text form
		openssl x509 -noout -text -in "$1"
	else
		echo "DER encoded"
		# Try der encoding
		openssl x509 -noout -text -inform DER -in "$1"
	fi
}

# Print a short summary of the certificate chain
openssl__certchain() {
	# $1: certfile
	[ -z "$1" ] && echo "Usage: openssl__certchain CERTFILE" && return 1

	openssl crl2pkcs7 -nocrl -certfile "$1" |
		openssl pkcs7 -print_certs -text -noout |
		tr -s " " | grep -Ei "^\s*subject:|^\s*issuer:|Not Before|Not After"
}

# List all defined shell functions and binaries in "$HOME"/bin
lsbin() {
	# Retrieve all currently defined shell functions and filter out the ones starting with _
	local shell_functions=$(declare -F | grep --color=never -oP 'declare -f \K([a-z]\w*)')

	# Everything in "$HOME"/bin
	bin_dir=$([ -d "$HOME"/bin ] && ls --color=never -1 "$HOME"/bin)

	echo "$shell_functions" "$bin_dir" | sort
}

# "Now" as Unix timestamp
unixtime_now() {
	date '+%s'
}

fvim() {
	SEARCH_ROOT="."
	if [ -n "$1" ] && [ -d "$1" ]; then
		SEARCH_ROOT="$1"
	fi
	find "$SEARCH_ROOT" -type f -print0 |
		fzf --read0 --print0 \
			--preview 'sed -n "1,200p" {}' \
			--preview-window=right:60% |
		xargs -0 -o vim
}

fkill() {
	ps -ef |
		fzf --header-lines=1 \
			--preview 'echo {}' \
			--preview-window=top:30% |
		awk '{print $2}' |
		xargs kill -9
}

fcd() {
	cd "$(find . -type d -maxdepth 2 |
		sort -n |
		fzf)" ||
		return
}

fgitlog() {
	git log --oneline --decorate |
		fzf --preview 'git show --color=always {1}'
}

# Prints the passed data as nice formatted table.
# The first arguments specify the column widhts.
# example:
# table 10 5 10 -- <<EOF
# Name Age City
# Alice 30 Berlin
# Bob 40 Hamburg
# EOF
table() {
	widths=

	while [ "$#" -gt "0" ]; do
		case $1 in
		--)
			shift
			break
			;;
		*[!0-9]* | '')
			echo "Usage: table WIDTH [WIDTH ...] --" >&2
			echo "Example: table 10 5 10 --" >&2
			return 1
			;;
		*)
			widths="${widths:+$widths }$1"
			shift
			;;
		esac
	done

	if [ -z "$widths" ]; then
		echo "Usage: table WIDTH [WIDTH ...] --" >&2
		return 1
	fi

	awk -v widths="$widths" '
	BEGIN {
		n = split(widths, w, " ")

		top = "┌"
		middle = "│"
		bottom = "└"

		for (i = 1; i <= n; i++) {
			h = sprintf("%" w[i] + 2 "s", "")
			gsub(/ /, "─", h)

			top = top h (i < n ? "┬" : "┐")
			middle = middle h (i < n ? "┼" : "┤")
			bottom = bottom h (i < n ? "┴" : "┘")
		}

		print top
	}

	NR == 1 {
		printf "│"
		for (i = 1; i <= n; i++)
			printf " %-*s │", w[i], $1
			printf "\n"

			print middle
			next
	}

	{
		printf "│"
		for (i = 1; i <= n; i++)
			printf " %-*s │", w[i], $i
		printf "\n"
	}

	END {
		print bottom
	}'
}

# ----------------------------------------------------------------------------
# Kubernetes
# ----------------------------------------------------------------------------
_kube_pod_select() {
	kubectl get pods --no-headers -o custom-columns=":metadata.name" |
		fzf
}

_kube_deployment_select() {
	kubectl get deployments --no-headers -o custom-columns=":metadata.names" |
		fzf
}

kp() {
	filter="$1"
	test -z "$1" && filter=""
	kubectl get pods | grep "$filter"
}

kpa() {
	filter="$1"
	test -z "$1" && filter=""
	kubectl get pods -A | grep "$filter"

}

klogf() {
	pod="$1"
	[ -z "$pod" ] && pod="$(_kube_pod_select)"
	kubectl logs -f "$pod"
}
